---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="This page doesn't exist." noindex>
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6">
    <p class="font-mono text-8xl font-bold text-border mb-6 select-none">404</p>
    <h1 class="font-mono text-2xl font-bold text-content-primary mb-3">Page not found</h1>
    <p class="text-content-secondary mb-8 max-w-sm">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="btn-primary">Go Home</a>
  </div>
</BaseLayout>
