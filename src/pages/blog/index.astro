---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import readingTime from 'reading-time';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect all unique categories and tags
const categories = ['All', ...new Set(allPosts.map(p => p.data.category))];
const featured   = allPosts.filter(p => p.data.featured);
const rest        = allPosts.filter(p => !p.data.featured);

function rt(body: string) { return readingTime(body).text; }
---

<BaseLayout
  title="Blog"
  description="In-depth articles on cryptocurrency, DeFi, blockchain technology, Web3, and crypto privacy. Research-backed content by Arvin Farrel Pramuditya."
  canonical="https://tradesaja.vercel.app/blog"
>

  <!-- Structured data for blog -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Trade Saja Blog',
    description: 'Cryptocurrency education and blockchain research articles',
    url: 'https://tradesaja.vercel.app/blog',
    author: { '@type': 'Person', name: 'Arvin Farrel Pramuditya' },
  })} />

  <!-- Page hero -->
  <div class="border-b border-border">
    <div class="max-w-6xl mx-auto px-6 pt-16 pb-12">
      <span class="eyebrow mb-5 inline-flex">Research Archive</span>
      <h1 class="font-mono font-bold text-[2rem] sm:text-[2.75rem] tracking-tight text-content-primary mb-3">
        All Articles
      </h1>
      <p class="text-content-secondary max-w-xl mb-8">
        In-depth research on cryptocurrency, blockchain technology, DeFi, and Web3.
        <span class="font-mono text-content-muted text-sm ml-2">{allPosts.length} articles</span>
      </p>

      <!-- Category filters (JS-powered) -->
      <div class="flex flex-wrap gap-2" id="filter-bar" role="group" aria-label="Filter by category">
        {categories.map(cat => (
          <button
            class="filter-btn font-mono text-[0.75rem] font-bold uppercase tracking-wide
                   px-4 py-2 rounded-lg border border-border text-content-secondary
                   hover:border-accent hover:text-accent hover:bg-accent/[0.05]
                   transition-all duration-150 cursor-pointer"
            data-filter={cat === 'All' ? 'all' : cat}
            aria-pressed={cat === 'All' ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-14">

    <!-- Featured pinned -->
    {featured.length > 0 && (
      <div class="mb-14" id="featured-section">
        <h2 class="section-title mb-6">Pinned</h2>
        <div class="grid grid-cols-1 gap-5">
          {featured.map(post => (
            <div data-category={post.data.category} class="article-item">
              <article class="bg-bg-card border border-border rounded-xl overflow-hidden
                              grid grid-cols-1 md:grid-cols-[1fr_2fr] group
                              hover:border-border-light transition-all duration-200">
                <!-- Image panel -->
                <div class="relative bg-gradient-to-br from-bg-secondary to-bg-card
                            border-b md:border-b-0 md:border-r border-border
                            min-h-[160px] flex items-center justify-center overflow-hidden">
                  <div class="absolute inset-0"
                       style="background-image: radial-gradient(circle at 30% 50%, rgba(59,130,246,0.1) 0%, transparent 60%), linear-gradient(rgba(59,130,246,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.04) 1px, transparent 1px); background-size: 100% 100%, 20px 20px, 20px 20px;">
                  </div>
                  <span class="relative text-4xl opacity-35 select-none">🔐</span>
                </div>
                <!-- Content -->
                <div class="p-8 flex flex-col justify-center">
                  <div class="flex items-center gap-2.5 mb-3">
                    <span class="inline-flex items-center gap-1 font-mono text-[0.6875rem] font-bold uppercase tracking-widest text-amber-400 bg-amber-400/[0.07] border border-amber-400/20 rounded px-2 py-0.5">★ Editor's Pick</span>
                    <span class="category-badge">{post.data.category}</span>
                  </div>
                  <h3 class="font-mono font-bold text-[1.2rem] leading-snug text-content-primary group-hover:text-white transition-colors mb-3">
                    <a href={`/blog/${post.slug}`} class="stretched-link">{post.data.title}</a>
                  </h3>
                  <p class="text-sm text-content-secondary leading-relaxed mb-5 line-clamp-2">{post.data.description}</p>
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {post.data.tags.slice(0,4).map(t => <span class="tag-pill">{t}</span>)}
                  </div>
                  <div class="meta-text">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}
                    </time>
                    <span class="meta-dot"></span>
                    <span>{rt(post.body)}</span>
                    <span class="meta-dot"></span>
                    <span>{post.data.author}</span>
                  </div>
                </div>
              </article>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- All posts grid -->
    <h2 class="section-title mb-6">All Posts</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="articles-grid">
      {allPosts.map(post => (
        <div data-category={post.data.category} class="article-item">
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            readingTime={rt(post.body)}
            category={post.data.category}
            tags={post.data.tags}
            featured={post.data.featured}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-20">
      <p class="font-mono text-content-muted text-sm">No articles in this category yet.</p>
    </div>

  </div>
</BaseLayout>

<style>
  .stretched-link::after { content: ''; position: absolute; inset: 0; }
  .filter-btn[aria-pressed="true"] {
    @apply border-accent text-accent bg-accent/[0.08];
  }
</style>

<script>
  const buttons   = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items     = document.querySelectorAll<HTMLElement>('.article-item');
  const empty     = document.getElementById('empty-state')!;

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Update active state
      buttons.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');

      // Filter items
      let visible = 0;
      items.forEach(item => {
        const cat = item.dataset.category!;
        const show = filter === 'all' || cat === filter;
        item.style.display = show ? '' : 'none';
        if (show) {
          visible++;
          item.style.animation = 'fade-up 0.3s ease forwards';
        }
      });

      empty.classList.toggle('hidden', visible > 0);
    });
  });
</script>
