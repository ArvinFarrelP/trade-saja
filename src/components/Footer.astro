---
const year = new Date().getFullYear();
---

<footer class="relative z-10 bg-bg-secondary border-t border-border mt-auto">
  <div class="max-w-6xl mx-auto px-6 pt-14 pb-8">

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 font-mono font-bold text-[1.05rem] text-content-primary mb-3">
          <span class="logo-dot"></span>
          Trade Saja
        </a>
        <p class="text-sm text-content-muted leading-relaxed max-w-[260px]">
          Cryptocurrency education and blockchain research. Rigorous analysis, accessible insights.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="font-mono text-[0.6875rem] font-bold uppercase tracking-widest text-content-muted mb-4">Navigation</p>
        <ul class="flex flex-col gap-2.5">
          {[['/', 'Home'], ['/blog', 'Blog'], ['/about', 'About']].map(([href, label]) => (
            <li><a href={href} class="text-sm text-content-secondary hover:text-accent transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Topics -->
      <div>
        <p class="font-mono text-[0.6875rem] font-bold uppercase tracking-widest text-content-muted mb-4">Topics</p>
        <ul class="flex flex-col gap-2.5">
          {['DeFi', 'Privacy', 'Bitcoin', 'Web3', 'Blockchain'].map(t => (
            <li><a href="/blog" class="text-sm text-content-secondary hover:text-accent transition-colors">{t}</a></li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <p class="font-mono text-[0.6875rem] font-bold uppercase tracking-widest text-content-muted mb-4">Connect</p>
        <ul class="flex flex-col gap-2.5">
          {[
            ['https://twitter.com/', 'Twitter / X'],
            ['https://github.com/',  'GitHub'],
            ['https://linkedin.com/', 'LinkedIn'],
            ['mailto:arvin@tradesaja.com', 'Email'],
          ].map(([href, label]) => (
            <li>
              <a href={href} target={href.startsWith('http') ? '_blank' : undefined}
                 rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                 class="text-sm text-content-secondary hover:text-accent transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 pt-7 border-t border-border">
      <p class="font-mono text-xs text-content-muted">
        © {year} Trade Saja · Arvin Farrel Pramuditya. All rights reserved.
      </p>

      <!-- Social icons -->
      <div class="flex gap-2.5">
        {[
          { href: 'https://twitter.com/', label: 'Twitter', path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
          { href: 'https://github.com/',  label: 'GitHub',  path: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z' },
        ].map(({ href, label, path }) => (
          <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label}
             class="w-8 h-8 flex items-center justify-center rounded-lg border border-border text-content-muted hover:border-accent hover:text-accent hover:bg-accent/[0.07] transition-all">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d={path}/></svg>
          </a>
        ))}
      </div>
    </div>

  </div>
</footer>
